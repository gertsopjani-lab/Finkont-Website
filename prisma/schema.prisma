// Finkont Prisma schema
// Database: PostgreSQL (per .cursorrules "strict relational PostgreSQL schemas")
// Models the accounting data-grid architecture described in design.md §3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// High-level direction of a ledger entry, drives semantic color tokens in the UI.
enum TransactionType {
  INCOME
  EXPENSE
}

/// Business accounting categories used by the data-grid "Category" column.
enum TransactionCategory {
  SALES
  SERVICES
  CONSULTING
  PAYROLL
  SOFTWARE
  MARKETING
  RENT
  UTILITIES
  TRAVEL
  TAXES
  OTHER
}

/// A single line item in the business ledger (design.md §3 Data Grid columns).
model Transaction {
  id        String              @id @default(cuid())
  lineItem  String
  date      DateTime
  category  TransactionCategory @default(OTHER)
  /// Stored as exact decimal money; negative values represent expenses.
  amount    Decimal             @db.Decimal(12, 2)
  type      TransactionType
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([date])
  @@index([type])
  @@index([category])
  @@map("transactions")
}
