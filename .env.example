# ---------------------------------------------------------------------------
# Contact form email delivery (server-side, used by app/api/send/route.ts)
# ---------------------------------------------------------------------------
# The form POSTs to /api/send, which sends the message via Resend.
# Without RESEND_API_KEY the endpoint returns a graceful "not configured"
# message instead of sending.
#
# Get your key at https://resend.com (API Keys). Set it in your host
# (Vercel > Project > Settings > Environment Variables) and, for Cloud Agent
# builds, in Cursor Dashboard > Cloud Agents > Secrets.

RESEND_API_KEY="re_your_api_key"

# Optional: override the recipient inbox (defaults to fin.kont2023@gmail.com).
CONTACT_TO="fin.kont2023@gmail.com"
