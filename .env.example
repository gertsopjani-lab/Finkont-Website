# ---------------------------------------------------------------------------
# Contact form email delivery (server-side, used by app/api/contact/route.ts)
# ---------------------------------------------------------------------------
# The form POSTs to /api/contact, which sends the message over SMTP.
# Without SMTP_USER and SMTP_PASSWORD the endpoint returns a graceful
# "not configured" message instead of sending.
#
# Gmail setup (recommended for fin.kont2023@gmail.com):
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password (Google Account > Security > App passwords).
#   3. Use that 16-character app password as SMTP_PASSWORD below.

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="fin.kont2023@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"

# Optional overrides:
# Inbox that receives submissions (defaults to siteConfig.email).
CONTACT_TO="fin.kont2023@gmail.com"
# From address (defaults to SMTP_USER). For Gmail this must be the account/alias.
CONTACT_FROM="fin.kont2023@gmail.com"
