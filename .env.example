# ---------------------------------------------------------------------------
# Contact form delivery (server-side, used by app/api/send/route.ts)
# ---------------------------------------------------------------------------
# The form POSTs to /api/send, which forwards the submission to Formspree.
# Without FORMSPREE_URL the endpoint returns a graceful "not configured"
# message instead of sending.
#
# Create a form at https://formspree.io and paste its endpoint URL here
# (e.g. https://formspree.io/f/xxxxxxxx).

FORMSPREE_URL="https://formspree.io/f/your_form_id"
